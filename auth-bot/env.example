# Copy to /etc/auth-bot/env (mode 600) and fill in real values.
# Get TOKEN from @BotFather (/newbot), then send /start to your bot to register OWNER_CHAT_ID.

AUTH_BOT_TOKEN=PUT_YOUR_BOT_TOKEN_HERE
OWNER_CHAT_ID=PUT_YOUR_TELEGRAM_USER_ID_HERE
TMUX_SESSION=claude-tg
CREDS_PATH=/root/.claude/.credentials.json
