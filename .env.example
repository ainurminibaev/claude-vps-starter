# Скопируй в /root/.env и заполни реальными значениями.
# НЕ коммить .env в git (он в .gitignore).

# Anthropic API key — получить в https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Токен Telegram-бота от @BotFather
TG_BOT_TOKEN=123456789:ABCdef...

# Для второго инстанса (жена/коллега) создавай .env отдельно
# в их домашней директории — /home/<user>/.env с их ключами.
